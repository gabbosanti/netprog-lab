#Il modubus server rappresenta il dispositivo industriale (es. un PLC) che riceve i comandi.

ip link set eth0 address 00:00:0a:00:02:02 #imposta un MAC address statico all'interfaccia eth0
ip addr add 200.1.1.8/24 dev eth0 #imposta un ip statico all'interfaccia eth0
route add default gw 200.1.1.1 dev eth0 #imposta il gateway predefinito
arp -s 200.1.1.1 00:00:00:00:00:04 #popola la tabella arp staticamente
python server.py &
python server_tls.py &
echo "modbusserver " >> /shared/startup.temp